generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CompanyStatus {
  DRAFT
  PENDING_KYC
  ACTIVE
  SUSPENDED
}

enum CompanyType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  LLP
  PRIVATE_LIMITED
  PUBLIC_LIMITED
  OTHER
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum KycDocumentType {
  CERTIFICATE_OF_INCORPORATION
  GST_CERTIFICATE
  PAN_CARD
  ADDRESS_PROOF
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
}

enum JobStatus {
  PUBLISHED
  CLOSED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum WorkplaceType {
  ONSITE
  HYBRID
  REMOTE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String              @unique
  passwordHash String              @map("password_hash")
  phone        String?
  status       UserStatus          @default(ACTIVE)
  memberships  CompanyMembership[]
  applications Application[]
  payments     Payment[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@map("users")
}

model Company {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  legalName          String              @map("legal_name")
  displayName        String              @map("display_name")
  companyType        CompanyType         @map("company_type")
  registrationNumber String?             @unique @map("registration_number")
  gstin              String?             @unique
  status             CompanyStatus       @default(DRAFT)
  memberships        CompanyMembership[]
  profile            CompanyProfile?
  kycVerification    KycVerification?
  jobs               Job[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([status])
  @@map("companies")
}

model CompanyMembership {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  userId    String      @map("user_id") @db.ObjectId
  companyId String      @map("company_id") @db.ObjectId
  role      CompanyRole
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([userId, companyId])
  @@index([companyId, role])
  @@map("company_memberships")
}

model CompanyProfile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId    String   @unique @map("company_id") @db.ObjectId
  description  String?
  logoUrl      String?  @map("logo_url")
  website      String?
  addressLine1 String?  @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  city         String?
  state        String?
  postalCode   String?  @map("postal_code")
  country      String   @default("IN")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("company_profiles")
}

model KycVerification {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String        @unique @map("company_id") @db.ObjectId
  status          KycStatus     @default(NOT_STARTED)
  submittedAt     DateTime?     @map("submitted_at")
  verifiedAt      DateTime?     @map("verified_at")
  rejectionReason String?       @map("rejection_reason")
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents       KycDocument[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@map("kyc_verifications")
}

model KycDocument {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  kycVerificationId String          @map("kyc_verification_id") @db.ObjectId
  type              KycDocumentType
  storageKey        String          @map("storage_key")
  fileName          String          @map("file_name")
  mimeType          String          @map("mime_type")
  status            DocumentStatus  @default(PENDING)
  rejectionReason   String?         @map("rejection_reason")
  kycVerification   KycVerification @relation(fields: [kycVerificationId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@unique([kycVerificationId, type])
  @@map("kyc_documents")
}

model Job {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  companyId          String              @map("company_id") @db.ObjectId
  title              String
  description        String
  location           String
  employmentType     EmploymentType      @map("employment_type")
  workplaceType      WorkplaceType       @map("workplace_type")
  status             JobStatus           @default(PUBLISHED)
  assessmentToken    String              @unique @map("assessment_token")
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skillThresholds    JobSkillThreshold[]
  applications       Application[]
  payments           Payment[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([companyId, status])
  @@index([status, createdAt])
  @@index([location])
  @@index([employmentType])
  @@index([workplaceType])
  @@index([createdAt])
  @@map("jobs")
}

model JobSkillThreshold {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId        String   @map("job_id") @db.ObjectId
  skill        String
  skillKey     String   @map("skill_key")
  minimumLevel Int      @map("minimum_level")
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([jobId, skillKey])
  @@index([skillKey, minimumLevel])
  @@map("job_skill_thresholds")
}

model Application {
  id              String                   @id @default(auto()) @map("_id") @db.ObjectId
  jobId           String                   @map("job_id") @db.ObjectId
  userId          String                   @map("user_id") @db.ObjectId
  status          ApplicationStatus        @default(PENDING)
  job             Job                      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateSkills CandidateSkill[]
  offer           Offer?
  interviews      Interview[]
  statusRecord    ApplicationStatusRecord?
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  @@unique([jobId, userId])
  @@index([status])
  @@map("applications")
}

model CandidateSkill {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  applicationId String      @map("application_id") @db.ObjectId
  skill         String
  skillKey      String      @map("skill_key")
  level         Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, skillKey])
  @@map("candidate_skills")
}

model Payment {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  userId           String        @map("user_id") @db.ObjectId
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId            String        @map("job_id") @db.ObjectId
  job              Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  amount           Int           // in paise
  currency         String        @default("INR")
  status           PaymentStatus @default(PENDING)
  gatewayOrderId   String        @unique @map("gateway_order_id")
  gatewayPaymentId String?       @map("gateway_payment_id")
  gatewaySignature String?       @map("gateway_signature")
  gatewayRefundId  String?       @map("gateway_refund_id")
  refundedAt       DateTime?     @map("refunded_at")
  failureReason    String?       @map("failure_reason")
  skillsJson       String        @map("skills_json")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Offer {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  applicationId     String      @unique @map("application_id") @db.ObjectId
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  salary            Int         // In INR (annual CTC)
  startDate         DateTime    @map("start_date")
  probationPeriod   Int         @default(3) @map("probation_period") // in months
  status            OfferStatus @default(PENDING)
  esignApproach     String?     @map("esign_approach") // "CRYPTOGRAPHIC" or "THIRD_PARTY"
  signature         String?
  signatureHash     String?     @map("signature_hash")
  candidateSignedAt DateTime?  @map("candidate_signed_at")
  candidateSignedIp String?    @map("candidate_signed_ip")
  providerTxId      String?     @map("provider_tx_id") // doc_xxxx
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("offers")
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Interview {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  applicationId   String          @map("application_id") @db.ObjectId
  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title           String
  scheduledAt     DateTime        @map("scheduled_at")
  duration        Int             @default(30) @map("duration") // in minutes
  status          InterviewStatus @default(SCHEDULED)
  meetingLink     String?         @map("meeting_link")
  interviewerName String?         @map("interviewer_name")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("interviews")
}

model ApplicationStatusRecord {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  applicationId String      @unique @map("application_id") @db.ObjectId
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        String      // "APPLIED", "SHORTLISTED", "INTERVIEWING", "OFFER_GENERATED", "OFFER_ACCEPTED", "OFFER_REJECTED", "OFFER_WITHDRAWN", "REJECTED"
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("application_statuses")
}


